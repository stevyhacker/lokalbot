!LokalBot.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
LokalBot.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/*
!LokalBot.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

